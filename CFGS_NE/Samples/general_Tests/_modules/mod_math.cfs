export const base = 100;

export func add(a, b) {
    return a + b;
}

export func scale(v, factor = 2) {
    return v * factor;
}

export class Acc(seed) {
    var value = 0;

    func init(seed) {
        this.value = seed;
    }

    func add(v) {
        this.value = this.value + v;
        return this.value;
    }

    func get() {
        return this.value;
    }
}

export enum Mode {
    Fast = 1,
    Safe = 2
}
