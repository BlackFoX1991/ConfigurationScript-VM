import { build_simple_sample_app } from "simple_sample_app.cfs";
import {
    assert_contains,
    assert_eq,
    assert_true,
    cookie_pair,
    json_body,
    request
} from "phase17_smoke_helpers.cfs";

func form_headers(cookie = null) {
    var headers = {
        "Host":"localhost:8096",
        "Content-Type":"application/x-www-form-urlencoded"
    };
    if (cookie != null) {
        headers["Cookie"] = cookie;
    }
    return headers;
}

async func main() {
    var app = build_simple_sample_app(0);

    var first_home = await app.handle(request("GET", "/"));
    var sid_pair = cookie_pair(first_home["headers"]["Set-Cookie"], "cfs_sid");
    assert_eq("home_status", first_home["status"], 200);
    assert_contains("home_title", first_home["body"], "Kleine Beispiel-App");
    assert_true("home_session_cookie_present", sid_pair != null);

    var invalid = await app.handle(request("POST", "/hello", "name=", form_headers(sid_pair)));
    var invalid_pair = cookie_pair(invalid["headers"]["Set-Cookie"], "cfs_sid");
    assert_eq("invalid_redirect_status", invalid["status"], 303);
    assert_eq("invalid_redirect_location", invalid["headers"]["Location"], "/");

    var invalid_home = await app.handle(request("GET", "/", "", {
        "Host":"localhost:8096",
        "Cookie": invalid_pair
    }));
    assert_contains("invalid_error_visible", invalid_home["body"], "Bitte gib einen Namen ein.");

    var valid = await app.handle(request("POST", "/hello", "name=Ada", form_headers(invalid_pair)));
    var valid_pair = cookie_pair(valid["headers"]["Set-Cookie"], "cfs_sid");
    assert_eq("valid_redirect_status", valid["status"], 303);
    assert_eq("valid_redirect_location", valid["headers"]["Location"], "/");

    var valid_home = await app.handle(request("GET", "/", "", {
        "Host":"localhost:8096",
        "Cookie": valid_pair
    }));
    assert_contains("flash_visible", valid_home["body"], "Hallo Ada!");

    var api = await app.handle(request("GET", "/api/ping", "", {
        "Host":"localhost:8096",
        "Cookie": valid_pair
    }));
    var api_body = json_body(api);
    assert_eq("api_status", api["status"], 200);
    assert_eq("api_ok", api_body["ok"], true);
    assert_eq("api_app_name", api_body["app"], "simple-sample");
    assert_eq("api_path", api_body["path"], "/api/ping");
    assert_true("api_visit_count_positive", api_body["visit_count"] >= 1);

    print("[done] simple_sample_app_smoke");
}

var _ = await main();
