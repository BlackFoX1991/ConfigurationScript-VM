import "plugins/CFGS.StandardLibrary.dll";
import { Util } from "common.cfs";
import { ServerApp } from "server.cfs";
import { Forms } from "forms.cfs";

func expect(label, actual, expected) {
    if (actual != expected) {
        throw label + " expected=" + str(expected) + " actual=" + str(actual);
    }
}

func expect_true(label, value) {
    if (!value) {
        throw label + " expected true";
    }
}

func set_cookie_value(set_cookie_header) {
    var first = str(set_cookie_header).split("\n")[0];
    var semi = first.indexOf(";");
    if (semi >= 0) {
        return first.substr(0, semi);
    }
    return first;
}

func extract_json_field(body, field_name) {
    return fromjson(body)[field_name];
}

async func main() {
    var app = new ServerApp(8092);
    app.set_session_timeouts(60, 600);

    app.get_named("token", "/token", func(ctx) {
        return ctx.response.json({
            "sid": ctx.sid,
            "csrf": ctx.request.csrf_token(),
            "field": ctx.request.csrf_field_name(),
            "hidden": Forms.csrf_field(ctx) != null
        });
    });

    app.post_named("submit", "/submit", func(ctx) {
        return ctx.response.text("ok");
    });

    app.post_named("go_back", "/go-back", func(ctx) {
        return ctx.response.back("/fallback");
    });

    app.get_named("rotate", "/rotate", func(ctx) {
        var before = ctx.sid;
        var after = ctx.response.rotate_session();
        return ctx.response.json({
            "before": before,
            "after": after
        });
    });

    var token_res = await app.handle({
        "method":"GET",
        "path":"/token",
        "query":"",
        "headers":{"Host":"localhost:8092"},
        "body":""
    });

    expect("token_status", token_res["status"], 200);
    var token_body = fromjson(token_res["body"]);
    var cookie = set_cookie_value(token_res["headers"]["Set-Cookie"]);
    var sid = token_body["sid"];
    var csrf = token_body["csrf"];
    var field = token_body["field"];

    expect_true("sid_randomized_prefix", Util.starts_with(sid, "sid_"));
    expect_true("sid_not_counter", sid != "sid_1");
    expect_true("sid_length", len(sid) > 20);
    expect_true("csrf_hidden_helper", token_body["hidden"] == true);

    var fail_res = await app.handle({
        "method":"POST",
        "path":"/submit",
        "query":"",
        "headers":{
            "Host":"localhost:8092",
            "Cookie":cookie,
            "Content-Type":"application/x-www-form-urlencoded"
        },
        "body":"name=test"
    });
    expect("csrf_missing_forbidden", fail_res["status"], 403);

    var bad_res = await app.handle({
        "method":"POST",
        "path":"/submit",
        "query":"",
        "headers":{
            "Host":"localhost:8092",
            "Cookie":cookie,
            "Content-Type":"application/x-www-form-urlencoded"
        },
        "body":"name=test&" + urlencode(field) + "=wrong"
    });
    expect("csrf_wrong_forbidden", bad_res["status"], 403);

    var ok_res = await app.handle({
        "method":"POST",
        "path":"/submit",
        "query":"",
        "headers":{
            "Host":"localhost:8092",
            "Cookie":cookie,
            "Content-Type":"application/x-www-form-urlencoded"
        },
        "body":"name=test&" + urlencode(field) + "=" + urlencode(csrf)
    });
    expect("csrf_ok_status", ok_res["status"], 200);
    expect("csrf_ok_body", ok_res["body"], "ok");

    var multipart_boundary = "----cfsBoundaryPhase1";
    var multipart_res = await app.handle({
        "method":"POST",
        "path":"/submit",
        "query":"",
        "headers":{
            "Host":"localhost:8092",
            "Cookie":cookie,
            "Content-Type":"multipart/form-data; boundary=" + multipart_boundary
        },
        "body":
            "--" + multipart_boundary + "\r\n" +
            "Content-Disposition: form-data; name=\"name\"\r\n\r\n" +
            "test\r\n" +
            "--" + multipart_boundary + "\r\n" +
            "Content-Disposition: form-data; name=\"" + field + "\"\r\n\r\n" +
            csrf + "\r\n" +
            "--" + multipart_boundary + "--\r\n"
    });
    expect("csrf_multipart_ok_status", multipart_res["status"], 200);
    expect("csrf_multipart_ok_body", multipart_res["body"], "ok");

    var evil_back = await app.handle({
        "method":"POST",
        "path":"/go-back",
        "query":"",
        "headers":{
            "Host":"localhost:8092",
            "Cookie":cookie,
            "Referer":"https://evil.example/boom",
            "Content-Type":"application/x-www-form-urlencoded"
        },
        "body":urlencode(field) + "=" + urlencode(csrf)
    });
    expect("back_evil_fallback", evil_back["headers"]["Location"], "/fallback");

    var safe_back = await app.handle({
        "method":"POST",
        "path":"/go-back",
        "query":"",
        "headers":{
            "Host":"localhost:8092",
            "Cookie":cookie,
            "Referer":"http://localhost:8092/from?page=1",
            "Content-Type":"application/x-www-form-urlencoded"
        },
        "body":urlencode(field) + "=" + urlencode(csrf)
    });
    expect("back_same_host_path", safe_back["headers"]["Location"], "/from?page=1");

    var rotate_res = await app.handle({
        "method":"GET",
        "path":"/rotate",
        "query":"",
        "headers":{
            "Host":"localhost:8092",
            "Cookie":cookie
        },
        "body":""
    });
    expect("rotate_status", rotate_res["status"], 200);
    var rotate_body = fromjson(rotate_res["body"]);
    expect_true("rotate_changes_sid", rotate_body["before"] != rotate_body["after"]);

    var old_cookie = cookie;
    var new_cookie = set_cookie_value(rotate_res["headers"]["Set-Cookie"]);

    var recycled = await app.handle({
        "method":"GET",
        "path":"/token",
        "query":"",
        "headers":{
            "Host":"localhost:8092",
            "Cookie":old_cookie
        },
        "body":""
    });
    var recycled_sid = extract_json_field(recycled["body"], "sid");
    expect_true("old_sid_rejected_after_rotate", recycled_sid != rotate_body["before"]);

    var fresh = await app.handle({
        "method":"GET",
        "path":"/token",
        "query":"",
        "headers":{
            "Host":"localhost:8092",
            "Cookie":new_cookie
        },
        "body":""
    });
    var fresh_sid = extract_json_field(fresh["body"], "sid");
    expect("new_sid_accepted_after_rotate", fresh_sid, rotate_body["after"]);

    app.sessions[rotate_body["after"]]["last_seen_at"] = Util.now_utc_unix_seconds() - 61;
    var expired = await app.handle({
        "method":"GET",
        "path":"/token",
        "query":"",
        "headers":{
            "Host":"localhost:8092",
            "Cookie":new_cookie
        },
        "body":""
    });
    var expired_sid = extract_json_field(expired["body"], "sid");
    expect_true("idle_timeout_reissues_session", expired_sid != rotate_body["after"]);

    print("PHASE1_SECURITY_OK");
}

var _ = await main();
