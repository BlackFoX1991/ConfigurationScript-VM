import { Forms } from "forms.cfs";
import { ServerApp } from "server.cfs";
import { Dom } from "dom.cfs";
import { Util } from "common.cfs";

func expect(label, actual, expected) {
    if (actual != expected) {
        throw label + " expected=" + str(expected) + " actual=" + str(actual);
    }
}

func expect_true(label, value) {
    if (!value) {
        throw label + " expected true";
    }
}

func request(method, path, body = "", headers = null) {
    return {
        "method": method,
        "path": path,
        "query": "",
        "headers": headers == null ? {"Host":"localhost:8102"} : headers,
        "body": body
    };
}

func find_cookie_line(set_cookie_header, name) {
    var lines = str(set_cookie_header).split("\n");
    var i = 0;
    while (i < len(lines)) {
        var line = lines[i];
        if (Util.starts_with(str(line), name + "=")) {
            return line;
        }
        i = i + 1;
    }
    return null;
}

func cookie_pair(cookie_line) {
    if (cookie_line == null) { return null; }
    var semi = str(cookie_line).indexOf(";");
    if (semi >= 0) {
        return str(cookie_line).substr(0, semi);
    }
    return str(cookie_line);
}

func contains_max_age(cookie_line) {
    return cookie_line != null && str(cookie_line).contains("Max-Age=");
}

func max_age_value(cookie_line) {
    if (cookie_line == null) { return null; }
    var parts = str(cookie_line).split(";");
    var i = 0;
    while (i < len(parts)) {
        var part = parts[i].trim();
        if (Util.starts_with(str(part), "Max-Age=")) {
            return part.substr(8, len(part) - 8);
        }
        i = i + 1;
    }
    return null;
}

async func main() {
    var app = new ServerApp(8102);
    app.set_session_timeouts(60, 600);

    app.get_named("touch", "/touch", func(ctx) {
        return ctx.response.json({
            "sid": ctx.sid,
            "visits": ctx.session["visits"]
        });
    });

    app.get_named("remember", "/remember", func(ctx) {
        return ctx.response.json({
            "ttl": ctx.response.remember_session()
        });
    });

    app.get_named("remember.custom", "/remember-custom", func(ctx) {
        return ctx.response.json({
            "ttl": ctx.response.remember_session(300)
        });
    });

    app.get_named("forget", "/forget", func(ctx) {
        ctx.response.forget_session();
        return ctx.response.text("forgot");
    });

    app.get_named("rotate", "/rotate", func(ctx) {
        var before = ctx.sid;
        var after = ctx.response.rotate_session();
        return ctx.response.json({
            "before": before,
            "after": after
        });
    });

    app.get_named("message.set", "/message-set", func(ctx) {
        return ctx.response.redirect_with_session_message("/message-view", "notice", "Persistent hello");
    });

    app.get_named("message.view", "/message-view", func(ctx) {
        return ctx.response.html(Dom.render(Dom.h("div", null, [
            Forms.session_message(ctx, "notice"),
            Dom.h("div", {"class":"session"}, ctx.request.session_message("notice", ""))
        ])));
    });

    app.get_named("message.clear", "/message-clear", func(ctx) {
        ctx.response.clear_session_message("notice");
        return ctx.response.text("cleared");
    });

    app.get_named("logout.fresh", "/logout-fresh", func(ctx) {
        var before = ctx.sid;
        var after = ctx.response.logout_session();
        return ctx.response.json({
            "before": before,
            "after": after
        });
    });

    app.get_named("logout.expire", "/logout-expire", func(ctx) {
        ctx.response.logout_session(false);
        return ctx.response.text("expired");
    });

    var first = await app.handle(request("GET", "/touch"));
    expect("first_status", first["status"], 200);
    var first_body = fromjson(first["body"]);
    var first_sid = first_body["sid"];
    var first_cookie_line = find_cookie_line(first["headers"]["Set-Cookie"], "cfs_sid");
    expect_true("first_cookie_present", first_cookie_line != null);
    expect_true("first_cookie_session_scoped", !contains_max_age(first_cookie_line));
    var first_cookie = cookie_pair(first_cookie_line);

    var remember = await app.handle(request("GET", "/remember", "", {
        "Host":"localhost:8102",
        "Cookie": first_cookie
    }));
    expect("remember_status", remember["status"], 200);
    expect("remember_ttl", fromjson(remember["body"])["ttl"], 60);
    var remember_cookie_line = find_cookie_line(remember["headers"]["Set-Cookie"], "cfs_sid");
    expect("remember_cookie_max_age", max_age_value(remember_cookie_line), "60");
    var remember_cookie = cookie_pair(remember_cookie_line);

    var rotate = await app.handle(request("GET", "/rotate", "", {
        "Host":"localhost:8102",
        "Cookie": remember_cookie
    }));
    expect("rotate_status", rotate["status"], 200);
    var rotate_body = fromjson(rotate["body"]);
    expect_true("rotate_sid_changed", rotate_body["before"] != rotate_body["after"]);
    var rotate_cookie_line = find_cookie_line(rotate["headers"]["Set-Cookie"], "cfs_sid");
    expect("rotate_cookie_max_age_kept", max_age_value(rotate_cookie_line), "60");
    var rotate_cookie = cookie_pair(rotate_cookie_line);

    var message_set = await app.handle(request("GET", "/message-set", "", {
        "Host":"localhost:8102",
        "Cookie": rotate_cookie
    }));
    expect("message_set_status", message_set["status"], 303);
    expect("message_set_location", message_set["headers"]["Location"], "/message-view");

    var message_view1 = await app.handle(request("GET", "/message-view", "", {
        "Host":"localhost:8102",
        "Cookie": rotate_cookie
    }));
    expect("message_view1_status", message_view1["status"], 200);
    expect_true("message_view1_contains", str(message_view1["body"]).contains("Persistent hello"));
    expect_true("message_view1_helper_rendered", str(message_view1["body"]).contains("session-message"));

    var message_view2 = await app.handle(request("GET", "/message-view", "", {
        "Host":"localhost:8102",
        "Cookie": rotate_cookie
    }));
    expect("message_view2_status", message_view2["status"], 200);
    expect_true("message_view2_still_contains", str(message_view2["body"]).contains("Persistent hello"));

    var message_clear = await app.handle(request("GET", "/message-clear", "", {
        "Host":"localhost:8102",
        "Cookie": rotate_cookie
    }));
    expect("message_clear_status", message_clear["status"], 200);

    var message_view3 = await app.handle(request("GET", "/message-view", "", {
        "Host":"localhost:8102",
        "Cookie": rotate_cookie
    }));
    expect("message_view3_status", message_view3["status"], 200);
    expect_true("message_view3_cleared", !str(message_view3["body"]).contains("Persistent hello"));

    var forget = await app.handle(request("GET", "/forget", "", {
        "Host":"localhost:8102",
        "Cookie": rotate_cookie
    }));
    expect("forget_status", forget["status"], 200);
    var forget_cookie_line = find_cookie_line(forget["headers"]["Set-Cookie"], "cfs_sid");
    expect_true("forget_cookie_session_scoped", !contains_max_age(forget_cookie_line));
    var forget_cookie = cookie_pair(forget_cookie_line);

    var remember_custom = await app.handle(request("GET", "/remember-custom", "", {
        "Host":"localhost:8102",
        "Cookie": forget_cookie
    }));
    expect("remember_custom_status", remember_custom["status"], 200);
    expect("remember_custom_ttl", fromjson(remember_custom["body"])["ttl"], 300);
    var remember_custom_cookie_line = find_cookie_line(remember_custom["headers"]["Set-Cookie"], "cfs_sid");
    expect("remember_custom_cookie_max_age", max_age_value(remember_custom_cookie_line), "300");
    var remember_custom_cookie = cookie_pair(remember_custom_cookie_line);

    var logout_fresh = await app.handle(request("GET", "/logout-fresh", "", {
        "Host":"localhost:8102",
        "Cookie": remember_custom_cookie
    }));
    expect("logout_fresh_status", logout_fresh["status"], 200);
    var logout_fresh_body = fromjson(logout_fresh["body"]);
    expect_true("logout_fresh_sid_changed", logout_fresh_body["before"] != logout_fresh_body["after"]);
    var logout_fresh_cookie_line = find_cookie_line(logout_fresh["headers"]["Set-Cookie"], "cfs_sid");
    expect_true("logout_fresh_cookie_no_max_age", !contains_max_age(logout_fresh_cookie_line));
    var logout_fresh_cookie = cookie_pair(logout_fresh_cookie_line);

    var old_cookie_rejected = await app.handle(request("GET", "/touch", "", {
        "Host":"localhost:8102",
        "Cookie": remember_custom_cookie
    }));
    expect_true("old_cookie_rejected", fromjson(old_cookie_rejected["body"])["sid"] != logout_fresh_body["before"]);

    var fresh_cookie_ok = await app.handle(request("GET", "/touch", "", {
        "Host":"localhost:8102",
        "Cookie": logout_fresh_cookie
    }));
    expect("fresh_cookie_ok_sid", fromjson(fresh_cookie_ok["body"])["sid"], logout_fresh_body["after"]);

    var logout_expire = await app.handle(request("GET", "/logout-expire", "", {
        "Host":"localhost:8102",
        "Cookie": logout_fresh_cookie
    }));
    expect("logout_expire_status", logout_expire["status"], 200);
    var logout_expire_cookie_line = find_cookie_line(logout_expire["headers"]["Set-Cookie"], "cfs_sid");
    expect("logout_expire_max_age_zero", max_age_value(logout_expire_cookie_line), "0");

    print("PHASE11_SESSION_LIFECYCLE_MESSAGES_OK");
}

var _ = await main();
