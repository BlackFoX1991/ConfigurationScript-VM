import { ServerApp } from "server.cfs";

func expect(label, actual, expected) {
    if (actual != expected) {
        throw label + " expected=" + str(expected) + " actual=" + str(actual);
    }
}

func expect_true(label, value) {
    if (!value) {
        throw label + " expected true";
    }
}

func request(method, path, body = "", headers = null) {
    return {
        "method": method,
        "path": path,
        "query": "",
        "headers": headers == null ? {"Host":"localhost:8109"} : headers,
        "body": body
    };
}

async func main() {
    var app = new ServerApp(8109);
    app.set_max_body_bytes(4);
    app.set_debug_errors(true);

    app.get("/teapot", func(ctx) {
        return ctx.response.error_page(418, "Teapot", "Friendly lead", "Brew failed");
    });

    app.get("/manual-debug", func(ctx) {
        return ctx.response.debug_page("manual detail", 500, "Manual Debug", "Manual lead");
    });

    app.get("/explode", func(ctx) {
        throw "debug explosion";
    });

    app.post("/limited", func(ctx) {
        return ctx.response.text("ok");
    }, {"csrf":false});

    var missing_text = await app.handle(request("GET", "/missing"));
    expect("missing_text_status", missing_text["status"], 404);
    expect("missing_text_body", missing_text["body"], "Not Found");
    expect("missing_text_content_type", missing_text["headers"]["Content-Type"], "text/plain; charset=utf-8");

    var missing_html = await app.handle(request("GET", "/missing", "", {
        "Host":"localhost:8109",
        "Accept":"text/html"
    }));
    expect("missing_html_status", missing_html["status"], 404);
    expect("missing_html_content_type", missing_html["headers"]["Content-Type"], "text/html; charset=utf-8");
    expect_true("missing_html_doctype", str(missing_html["body"]).contains("<!doctype html>"));
    expect_true("missing_html_title", str(missing_html["body"]).contains("Not Found"));
    expect_true("missing_html_path", str(missing_html["body"]).contains("GET /missing"));

    var method_html = await app.handle(request("POST", "/teapot", "", {
        "Host":"localhost:8109",
        "Accept":"text/html"
    }));
    expect("method_html_status", method_html["status"], 405);
    expect("method_html_allow", method_html["headers"]["Allow"], "GET, HEAD, OPTIONS");
    expect_true("method_html_body", str(method_html["body"]).contains("Method Not Allowed"));
    expect_true("method_html_detail", str(method_html["body"]).contains("Allowed methods: GET, HEAD, OPTIONS"));

    var payload_html = await app.handle(request("POST", "/limited", "12345", {
        "Host":"localhost:8109",
        "Accept":"text/html",
        "Content-Type":"text/plain; charset=utf-8"
    }));
    expect("payload_html_status", payload_html["status"], 413);
    expect_true("payload_html_title", str(payload_html["body"]).contains("Payload Too Large"));
    expect_true("payload_html_detail", str(payload_html["body"]).contains("Configured limit: 4 bytes. Received: 5 bytes."));

    var teapot = await app.handle(request("GET", "/teapot"));
    expect("teapot_status", teapot["status"], 418);
    expect("teapot_content_type", teapot["headers"]["Content-Type"], "text/html; charset=utf-8");
    expect_true("teapot_lead", str(teapot["body"]).contains("Friendly lead"));
    expect_true("teapot_detail", str(teapot["body"]).contains("Brew failed"));

    var manual_debug = await app.handle(request("GET", "/manual-debug"));
    expect("manual_debug_status", manual_debug["status"], 500);
    expect_true("manual_debug_title", str(manual_debug["body"]).contains("Manual Debug"));
    expect_true("manual_debug_detail", str(manual_debug["body"]).contains("manual detail"));

    var explode_html = await app.handle(request("GET", "/explode", "", {
        "Host":"localhost:8109",
        "Accept":"text/html"
    }));
    expect("explode_html_status", explode_html["status"], 500);
    expect_true("explode_html_title", str(explode_html["body"]).contains("Internal Server Error"));
    expect_true("explode_html_debug", str(explode_html["body"]).contains("debug explosion"));
    expect_true("explode_html_request", str(explode_html["body"]).contains("GET /explode"));
    expect_true("explode_html_panel", str(explode_html["body"]).contains("Request Data"));

    var explode_text = await app.handle(request("GET", "/explode"));
    expect("explode_text_status", explode_text["status"], 500);
    expect_true("explode_text_body", str(explode_text["body"]).contains("Internal Server Error"));
    expect_true("explode_text_debug", str(explode_text["body"]).contains("debug explosion"));

    print("PHASE16_ERROR_DEBUG_OK");
}

var _ = await main();
