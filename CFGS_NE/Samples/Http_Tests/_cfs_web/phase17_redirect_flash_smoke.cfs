import "plugins/CFGS.StandardLibrary.dll";
import { ServerApp } from "server.cfs";
import {
    assert_eq,
    assert_not_eq,
    cookie_pair,
    json_body,
    request
} from "phase17_smoke_helpers.cfs";

func build_app() {
    var app = new ServerApp(0);

    app.get_named("form", "/form", func(ctx) {
        return ctx.response.json({
            "flash": ctx.request.flash("notice", null),
            "banner": ctx.request.session_message("banner", null),
            "old": ctx.request.old("title", null),
            "old_error": ctx.request.old_error("title", null)
        });
    });

    app.post("/fail", func(ctx) {
        ctx.response.session_message("banner", "persist");
        return ctx.response.redirect_to_with_input("form", {
            "title":"Draft"
        }, {
            "title":"Required"
        });
    }, {
        "csrf": false
    });

    app.post("/success", func(ctx) {
        ctx.response.session_message("banner", "persist");
        ctx.response.flash("notice", "Saved");
        return ctx.response.redirect_to("form");
    }, {
        "csrf": false
    });

    app.post("/clear-banner", func(ctx) {
        ctx.response.clear_session_message("banner");
        return ctx.response.redirect_to("form");
    }, {
        "csrf": false
    });

    app.get("/back", func(ctx) {
        return ctx.response.back("/", 302);
    });

    return app;
}

async func main() {
    var app = build_app();

    var fail = await app.handle(request("POST", "/fail"));
    var sid_pair = cookie_pair(fail["headers"]["Set-Cookie"], "cfs_sid");
    assert_eq("fail_redirect_status", fail["status"], 303);
    assert_eq("fail_redirect_location", fail["headers"]["Location"], "/form");

    var after_fail = await app.handle(request("GET", "/form", "", {
        "Host":"localhost:8094",
        "Cookie": sid_pair
    }));
    var after_fail_body = json_body(after_fail);
    assert_eq("after_fail_old_value", after_fail_body["old"], "Draft");
    assert_eq("after_fail_old_error", after_fail_body["old_error"], "Required");
    assert_eq("after_fail_banner", after_fail_body["banner"], "persist");
    assert_eq("after_fail_flash", after_fail_body["flash"], null);

    var second_form = await app.handle(request("GET", "/form", "", {
        "Host":"localhost:8094",
        "Cookie": sid_pair
    }));
    var second_form_body = json_body(second_form);
    assert_eq("old_value_consumed", second_form_body["old"], null);
    assert_eq("old_error_consumed", second_form_body["old_error"], null);
    assert_eq("banner_persists", second_form_body["banner"], "persist");

    var success = await app.handle(request("POST", "/success", "", {
        "Host":"localhost:8094",
        "Cookie": sid_pair
    }));
    var success_pair = cookie_pair(success["headers"]["Set-Cookie"], "cfs_sid");
    assert_eq("success_redirect_status", success["status"], 303);
    assert_eq("success_redirect_location", success["headers"]["Location"], "/form");

    var after_success = await app.handle(request("GET", "/form", "", {
        "Host":"localhost:8094",
        "Cookie": success_pair
    }));
    var after_success_body = json_body(after_success);
    assert_eq("flash_visible_once", after_success_body["flash"], "Saved");
    assert_eq("banner_still_present", after_success_body["banner"], "persist");

    var after_flash_consumed = await app.handle(request("GET", "/form", "", {
        "Host":"localhost:8094",
        "Cookie": success_pair
    }));
    var after_flash_consumed_body = json_body(after_flash_consumed);
    assert_eq("flash_consumed", after_flash_consumed_body["flash"], null);
    assert_eq("banner_still_persists", after_flash_consumed_body["banner"], "persist");

    var clear = await app.handle(request("POST", "/clear-banner", "", {
        "Host":"localhost:8094",
        "Cookie": success_pair
    }));
    var clear_pair = cookie_pair(clear["headers"]["Set-Cookie"], "cfs_sid");
    assert_eq("clear_redirect_status", clear["status"], 303);
    assert_eq("clear_redirect_location", clear["headers"]["Location"], "/form");

    var after_clear = await app.handle(request("GET", "/form", "", {
        "Host":"localhost:8094",
        "Cookie": clear_pair
    }));
    var after_clear_body = json_body(after_clear);
    assert_eq("banner_cleared", after_clear_body["banner"], null);

    var safe_back = await app.handle(request("GET", "/back", "", {
        "Host":"localhost:8094",
        "Referer":"http://localhost:8094/form?via=back"
    }));
    assert_eq("back_same_host", safe_back["headers"]["Location"], "/form?via=back");

    var unsafe_back = await app.handle(request("GET", "/back", "", {
        "Host":"localhost:8094",
        "Referer":"http://evil.test/form?via=bad"
    }));
    assert_eq("back_foreign_host_fallback", unsafe_back["headers"]["Location"], "/");

    assert_not_eq("fresh_session_cookie_stable", clear_pair, null);
    print("[done] phase17_redirect_flash_smoke");
}

var _ = await main();
