import { build_example_app } from "example_app.cfs";
import {
    assert_contains,
    assert_eq,
    assert_true
} from "phase17_smoke_helpers.cfs";

func request_headers() {
    return {
        "User-Agent":"CFGS-Phase18-Live-Smoke/1.0"
    };
}

async func wait_for_get(url, attempts = 40, delay_ms = 100) {
    var waiter = task();
    var last_error = null;
    var i = 0;

    while (i < attempts) {
        try {
            return await http_get(url, request_headers(), 2000);
        } catch (e) {
            last_error = e;
        }

        var _pause = await waiter.delay(delay_ms);
        i = i + 1;
    }

    throw "wait_for_get failed for " + url + ": " + str(last_error);
}

async func main() {
    var port = 5098;
    var base = "http://localhost:" + str(port);
    var app = build_example_app(port);
    var run_task = null;
    var stopped = false;

    try {
        run_task = app.run();

        var home = await wait_for_get(base + "/");
        assert_eq("home_status", home["status"], 200);
        assert_contains("home_content_type", home["headers"]["Content-Type"], "text/html");
        assert_eq("home_example_header", home["headers"]["X-CFS-Example"], "workshop-board");
        assert_contains("home_title", home["body"], "<title>Workshop Board</title>");

        var meta = await http_get(base + "/api/meta", request_headers(), 2000);
        var meta_json = fromjson(meta["body"]);
        assert_eq("meta_status", meta["status"], 200);
        assert_contains("meta_content_type", meta["headers"]["Content-Type"], "application/json");
        assert_contains("meta_asset_url", meta_json["asset_url"], "/assets/example.css");
        assert_true("meta_csrf_token_present", meta_json["csrf_token"] != null && meta_json["csrf_token"] != "");

        var asset = await http_get(base + "/assets/example.css", request_headers(), 2000);
        assert_eq("asset_status", asset["status"], 200);
        assert_contains("asset_content_type", asset["headers"]["Content-Type"], "text/css");
        assert_contains("asset_cache_control", asset["headers"]["Cache-Control"], "max-age=900");
        assert_contains("asset_body", asset["body"], "linear-gradient");

        var asset_head = await http_head(base + "/assets/example.css", request_headers(), 2000);
        assert_eq("asset_head_status", asset_head["status"], 200);
        assert_eq("asset_head_bodyless", asset_head["body"], "");
        assert_true("asset_head_etag_present", asset_head["headers"]["ETag"] != null && asset_head["headers"]["ETag"] != "");

        print("[done] phase18_live_listener_smoke");

        app.request_stop();
        var _done = await run_task;
        stopped = true;
    } finally {
        if (!stopped && run_task != null) {
            try {
                var _req_stop = app.request_stop();
            } catch (stop_err) {
            }

            try {
                var _cleanup = await run_task;
            } catch (cleanup_err) {
            }
        }
    }
}

var _ = await main();
