import "plugins/CFGS.StandardLibrary.dll";
import "plugins/CFGS.Web.Http.dll";
import { Util } from "common.cfs";
import { ServerApp } from "server.cfs";

func expect(label, actual, expected) {
    if (actual != expected) {
        throw label + " expected=" + str(expected) + " actual=" + str(actual);
    }
}

func expect_true(label, value) {
    if (!value) {
        throw label + " expected true";
    }
}

func request(method, path, body = "", headers = null) {
    return {
        "method": method,
        "path": path,
        "query": "",
        "headers": headers == null ? {"Host":"localhost:8093"} : headers,
        "body": body
    };
}

async func wait_for_server(url, timer, attempts = 40, delay_ms = 25) {
    var i = 0;
    while (i < attempts) {
        try {
            return await http_head(url);
        } catch (e) {
            var _ = await timer.delay(delay_ms);
        }
        i = i + 1;
    }

    throw "server_warmup_failed";
}

async func exercise_server(wait) {
    var exit_requested = false;
    try {
        var _warm = await wait_for_server("http://localhost:8093/head-check", wait);

        var start_ms = Util.now_utc_unix_milliseconds();
        var pair = await [
            http_get("http://localhost:8093/slow"),
            http_get("http://localhost:8093/slow")
        ];
        var elapsed_ms = Util.now_utc_unix_milliseconds() - start_ms;

        expect("slow_a_status", pair[0]["status"], 200);
        expect("slow_b_status", pair[1]["status"], 200);
        expect("slow_a_body", pair[0]["body"], "slow");
        expect("slow_b_body", pair[1]["body"], "slow");
        expect_true("parallel_elapsed_under_350ms", elapsed_ms < 350);

        var head_res = await http_head("http://localhost:8093/head-check");
        expect("head_status", head_res["status"], 200);
        expect("head_async_header", head_res["headers"]["X-Async-Pipeline"], "1");

        var exit_res = await http_get("http://localhost:8093/exit");
        exit_requested = true;
        expect("exit_status", exit_res["status"], 200);
        expect("exit_body", exit_res["body"], "bye");
        return 1;
    } finally {
        if (!exit_requested) {
            try {
                var _cleanup = await http_get("http://localhost:8093/exit");
            } catch (e) {
            }
        }
    }
}

async func main() {
    var wait = task();
    var app = new ServerApp(8093);

    app.use_before(async func(ctx) {
        if (ctx.req.path == "/short") {
            var _ = await wait.delay(10);
            return ctx.response.text("short");
        }

        var _b = await wait.delay(5);
        ctx.locals["before_async"] = "1";
        return null;
    });

    app.use_after(async func(ctx, res) {
        var _ = await wait.delay(5);
        var headers = res["headers"];
        if (headers == null) {
            headers = {};
            res["headers"] = headers;
        }
        headers["X-Async-Pipeline"] = "1";
        return res;
    });

    app.use_error(async func(ctx, err) {
        var _ = await wait.delay(5);
        return ctx.response.text("ERR:" + str(err), 500);
    });

    app.get_named("hello", "/hello/:name", async func(ctx) {
        var _ = await wait.delay(10);
        expect("before_local_visible", ctx.locals["before_async"], "1");
        return ctx.response.text("Hello " + ctx.request.param("name"));
    });

    app.get_named("boom", "/boom", async func(ctx) {
        var _ = await wait.delay(10);
        throw "boom";
    });

    app.head_named("head.check", "/head-check", async func(ctx) {
        var _ = await wait.delay(5);
        return ctx.response.text("head-body");
    });

    app.serve_static_with("/static/", async func(rel) {
        var _ = await wait.delay(5);
        if (rel == "async.txt") {
            return {
                "data":"async-static",
                "content_type":"text/plain; charset=utf-8"
            };
        }
        return null;
    }, 60);

    app.get_named("slow", "/slow", async func(ctx) {
        var _ = await wait.delay(200);
        return ctx.response.text("slow");
    });

    app.get_named("exit", "/exit", func(ctx) {
        ctx.app.request_stop();
        return ctx.response.text("bye");
    });

    var hello = await app.handle(request("GET", "/hello/world"));
    expect("hello_status", hello["status"], 200);
    expect("hello_body", hello["body"], "Hello world");
    expect("hello_after_header", hello["headers"]["X-Async-Pipeline"], "1");

    var short = await app.handle(request("GET", "/short"));
    expect("short_status", short["status"], 200);
    expect("short_body", short["body"], "short");
    expect("short_after_header", short["headers"]["X-Async-Pipeline"], "1");

    var boom = await app.handle(request("GET", "/boom"));
    expect("boom_status", boom["status"], 500);
    expect_true("boom_body_contains", str(boom["body"]).contains("boom"));
    expect("boom_after_header", boom["headers"]["X-Async-Pipeline"], "1");

    var static_res = await app.handle(request("GET", "/static/async.txt"));
    expect("static_status", static_res["status"], 200);
    expect("static_body", static_res["body"], "async-static");
    expect("static_after_header", static_res["headers"]["X-Async-Pipeline"], "1");

    var head_direct = await app.handle(request("HEAD", "/head-check"));
    expect("head_direct_status", head_direct["status"], 200);
    expect("head_direct_body_empty", head_direct["body"], "");
    expect("head_direct_after_header", head_direct["headers"]["X-Async-Pipeline"], "1");

    var head_static = await app.handle(request("HEAD", "/static/async.txt"));
    expect("head_static_status", head_static["status"], 200);
    expect("head_static_body_empty", head_static["body"], "");
    expect("head_static_after_header", head_static["headers"]["X-Async-Pipeline"], "1");

    var runner = app.run();
    var _done = await [runner, exercise_server(wait)];
    print("PHASE2_ASYNC_OK");
}

var _ = await main();
