import { build_mini_task_sample_app } from "mini_task_sample_app.cfs";
import {
    assert_contains,
    assert_eq,
    assert_not_eq,
    assert_true,
    cookie_pair,
    cookie_value,
    json_body,
    request
} from "phase17_smoke_helpers.cfs";

func form_headers(cookie = null) {
    var headers = {
        "Host":"localhost:8097",
        "Content-Type":"application/x-www-form-urlencoded"
    };
    if (cookie != null) {
        headers["Cookie"] = cookie;
    }
    return headers;
}

func csrf_body(token, extra) {
    var body = "__csrf=" + urlencode(str(token));
    if (extra != null && extra != "") {
        body = body + "&" + extra;
    }
    return body;
}

func active_cookie(set_cookie_header, fallback) {
    var pair = cookie_pair(set_cookie_header, "cfs_sid");
    return pair == null ? fallback : pair;
}

async func main() {
    var app = build_mini_task_sample_app(0);

    var first_home = await app.handle(request("GET", "/"));
    var sid_pair = cookie_pair(first_home["headers"]["Set-Cookie"], "cfs_sid");
    var sid = cookie_value(sid_pair);
    assert_eq("home_status", first_home["status"], 200);
    assert_contains("home_title", first_home["body"], "Mini Aufgaben-App");
    assert_contains("guest_login_section", first_home["body"], "Login");
    assert_true("session_cookie_present", sid_pair != null);

    var invalid_login = await app.handle(request("POST", "/auth/login", csrf_body(app.sessions[sid]["data"]["__csrf_token"], "login_name=A"), form_headers(sid_pair)));
    assert_eq("invalid_login_redirect", invalid_login["status"], 303);
    assert_eq("invalid_login_location", invalid_login["headers"]["Location"], "/");

    var after_invalid = await app.handle(request("GET", "/", "", {
        "Host":"localhost:8097",
        "Cookie": sid_pair
    }));
    assert_contains("invalid_login_error_visible", after_invalid["body"], "Name muss mindestens 2 Zeichen lang sein.");

    var valid_login = await app.handle(request("POST", "/auth/login", csrf_body(app.sessions[sid]["data"]["__csrf_token"], "login_name=Ada"), form_headers(sid_pair)));
    sid_pair = active_cookie(valid_login["headers"]["Set-Cookie"], sid_pair);
    sid = cookie_value(sid_pair);
    assert_eq("valid_login_redirect", valid_login["status"], 303);
    assert_eq("valid_login_location", valid_login["headers"]["Location"], "/");

    var after_login = await app.handle(request("GET", "/", "", {
        "Host":"localhost:8097",
        "Cookie": sid_pair
    }));
    assert_contains("login_flash_visible", after_login["body"], "Willkommen Ada!");
    assert_contains("login_user_visible", after_login["body"], "Aktiver Benutzer: Ada");

    var add_task = await app.handle(request("POST", "/tasks/create", csrf_body(app.sessions[sid]["data"]["__csrf_token"], "task_text=Release+Notizen"), form_headers(sid_pair)));
    sid_pair = active_cookie(add_task["headers"]["Set-Cookie"], sid_pair);
    assert_eq("add_task_redirect", add_task["status"], 303);
    assert_eq("add_task_location", add_task["headers"]["Location"], "/");

    var after_add = await app.handle(request("GET", "/", "", {
        "Host":"localhost:8097",
        "Cookie": sid_pair
    }));
    assert_contains("task_text_visible", after_add["body"], "Release Notizen");
    assert_contains("task_saved_flash_visible", after_add["body"], "Aufgabe gespeichert.");

    var toggle_task = await app.handle(request("POST", "/tasks/1/toggle", csrf_body(app.sessions[sid]["data"]["__csrf_token"], ""), form_headers(sid_pair)));
    assert_eq("toggle_redirect", toggle_task["status"], 303);
    assert_eq("toggle_location", toggle_task["headers"]["Location"], "/");

    var after_toggle = await app.handle(request("GET", "/", "", {
        "Host":"localhost:8097",
        "Cookie": sid_pair
    }));
    assert_contains("task_done_visible", after_toggle["body"], "Erledigt: True");

    var api = await app.handle(request("GET", "/api/state", "", {
        "Host":"localhost:8097",
        "Cookie": sid_pair
    }));
    var api_body = json_body(api);
    assert_eq("api_status", api["status"], 200);
    assert_eq("api_authenticated", api_body["authenticated"], true);
    assert_eq("api_user_name", api_body["user_name"], "Ada");
    assert_eq("api_task_count", api_body["task_count"], 1);
    assert_eq("api_open_count_after_toggle", api_body["open_count"], 0);

    var delete_task = await app.handle(request("POST", "/tasks/1/delete", csrf_body(app.sessions[sid]["data"]["__csrf_token"], ""), form_headers(sid_pair)));
    assert_eq("delete_redirect", delete_task["status"], 303);
    assert_eq("delete_location", delete_task["headers"]["Location"], "/");

    var after_delete = await app.handle(request("GET", "/", "", {
        "Host":"localhost:8097",
        "Cookie": sid_pair
    }));
    assert_contains("empty_list_visible", after_delete["body"], "Noch keine Aufgabe gespeichert.");

    var logout = await app.handle(request("POST", "/auth/logout", csrf_body(app.sessions[sid]["data"]["__csrf_token"], ""), form_headers(sid_pair)));
    var sid_pair_after_logout = active_cookie(logout["headers"]["Set-Cookie"], sid_pair);
    var sid_after_logout = cookie_value(sid_pair_after_logout);
    assert_eq("logout_redirect", logout["status"], 303);
    assert_eq("logout_location", logout["headers"]["Location"], "/");
    assert_not_eq("logout_rotates_session", sid_after_logout, sid);

    var after_logout = await app.handle(request("GET", "/", "", {
        "Host":"localhost:8097",
        "Cookie": sid_pair_after_logout
    }));
    assert_contains("logout_flash_visible", after_logout["body"], "Abgemeldet: Ada.");
    assert_contains("guest_view_visible_after_logout", after_logout["body"], "Login");

    print("[done] mini_task_sample_app_smoke");
}

var _ = await main();
