import "plugins/CFGS.StandardLibrary.dll";
import { Util } from "common.cfs";
import { ServerApp } from "server.cfs";

func repr(value) {
    try {
        return tojson(value);
    } catch (e) {
        return str(value);
    }
}

func assert_eq(name, actual, expected) {
    var left = repr(actual);
    var right = repr(expected);

    if (left != right) {
        throw "assert_eq failed: " + name + "\nactual: " + left + "\nexpected: " + right;
    }

    print("[ok] " + name);
}

func request(method, path, body = "", headers = null, remote = null) {
    var actual_headers = headers == null ? {"Host":"localhost:8094"} : headers;
    var actual_path = path;
    var actual_query = "";
    var qmark = path == null ? -1 : str(path).indexOf("?");

    if (qmark >= 0) {
        actual_path = str(path).substr(0, qmark);
        actual_query = str(path).substr(qmark + 1, len(str(path)) - (qmark + 1));
    }

    return {
        "method": method,
        "path": actual_path,
        "query": actual_query,
        "headers": actual_headers,
        "body": body,
        "remote": remote
    };
}

func cookie_pair(set_cookie_header, name) {
    if (set_cookie_header == null || name == null || name == "") {
        return null;
    }

    var lines = str(set_cookie_header).split("\n");
    var wanted = str(name) + "=";
    var i = 0;
    while (i < len(lines)) {
        var line = lines[i].trim();
        if (line != "") {
            var semi = line.indexOf(";");
            var pair = semi < 0 ? line : line.substr(0, semi);
            if (Util.starts_with(pair, wanted)) {
                return pair;
            }
        }
        i = i + 1;
    }

    return null;
}

async func smoke_cookie_roundtrip() {
    var app = new ServerApp(0);

    app.get("/set", func(ctx) {
        var res = ctx.response.text("set");
        return ctx.response.with_cookie(res, "demo", "a;b c", {"Path":"/"});
    });

    app.get("/read", func(ctx) {
        return ctx.response.text(ctx.request.cookie("demo", "missing"));
    });

    var set_res = await app.handle(request("GET", "/set"));
    var demo_cookie = cookie_pair(set_res["headers"]["Set-Cookie"], "demo");
    assert_eq("cookie_header_present", demo_cookie != null, true);

    var read_res = await app.handle(request("GET", "/read", "", {
        "Host":"localhost:8094",
        "Cookie": demo_cookie
    }));

    assert_eq("cookie_roundtrip", read_res["body"], "a;b c");
}

async func smoke_repeated_query_and_form_values() {
    var app = new ServerApp(0);

    app.get_named("search", "/search", func(ctx) {
        return ctx.response.text(tojson(ctx.request.query("tag")));
    });

    app.post("/form", func(ctx) {
        return ctx.response.text(tojson(ctx.request.form("tag")));
    }, {"csrf": false});

    var query_res = await app.handle(request("GET", "/search?tag=alpha&tag=beta"));
    assert_eq("query_repeated_values", fromjson(query_res["body"]), ["alpha", "beta"]);

    var form_res = await app.handle(request("POST", "/form", "tag=alpha&tag=beta", {
        "Host":"localhost:8094",
        "Content-Type":"application/x-www-form-urlencoded"
    }));
    assert_eq("form_repeated_values", fromjson(form_res["body"]), ["alpha", "beta"]);

    assert_eq(
        "build_query_array",
        app.url("search", null, {"tag":["alpha", "beta"]}),
        "/search?tag=alpha&tag=beta"
    );
}

async func smoke_upload_utf8_size() {
    var app = new ServerApp(0);

    app.post("/upload", func(ctx) {
        var file = ctx.request.upload("attachment", null);
        return ctx.response.text(file == null ? "missing" : str(file["size"]));
    }, {"csrf": false});

    var boundary = "----cfs-phase16";
    var body =
        "--" + boundary + "\r\n" +
        "Content-Disposition: form-data; name=\"attachment\"; filename=\"x.txt\"\r\n" +
        "Content-Type: text/plain\r\n\r\n" +
        "\u00E4\r\n" +
        "--" + boundary + "--\r\n";

    var res = await app.handle(request("POST", "/upload", body, {
        "Host":"localhost:8094",
        "Content-Type":"multipart/form-data; boundary=" + boundary
    }));

    assert_eq("upload_utf8_size", res["body"], "2");
}

async func main() {
    await smoke_cookie_roundtrip();
    await smoke_repeated_query_and_form_values();
    await smoke_upload_utf8_size();
    print("[done] phase16_framework_regression_smoke");
}

var _ = await main();
