import { Dom } from "dom.cfs";
import { Forms } from "forms.cfs";
import { ServerApp } from "server.cfs";
import { Validation } from "validation.cfs";

func expect(label, actual, expected) {
    if (actual != expected) {
        throw label + " expected=" + str(expected) + " actual=" + str(actual);
    }
}

func expect_true(label, value) {
    if (!value) {
        throw label + " expected true";
    }
}

func request(method, path, body = "", headers = null) {
    return {
        "method": method,
        "path": path,
        "query": "",
        "headers": headers == null ? {"Host":"localhost:8098"} : headers,
        "body": body
    };
}

func set_cookie_value(set_cookie_header) {
    var first = str(set_cookie_header).split("\n")[0];
    var semi = first.indexOf(";");
    if (semi >= 0) {
        return first.substr(0, semi);
    }
    return first;
}

func upload_count(value) {
    if (value == null) { return 0; }
    if (typeof(value) == "Array") { return len(value); }
    return 1;
}

async func main() {
    var app = new ServerApp(8098);

    app.serve_static_map("/assets/", {
        "timed.txt": {
            "data": "Timed body",
            "content_type": "text/plain; charset=utf-8",
            "last_modified": "Wed, 01 Apr 2026 10:30:00 GMT"
        }
    }, 120);

    app.post_named("upload.inspect", "/upload-inspect", func(ctx) {
        var avatar = ctx.request.upload("avatar");
        var gallery = ctx.request.uploads("gallery");

        return ctx.response.json({
            "title": ctx.request.form("title"),
            "avatar_name": avatar == null ? null : avatar["filename"],
            "avatar_original": avatar == null ? null : avatar["original_filename"],
            "avatar_type": avatar == null ? null : avatar["content_type"],
            "avatar_body": avatar == null ? null : avatar["body"],
            "avatar_size": avatar == null ? -1 : avatar["size"],
            "gallery_count": upload_count(gallery),
            "gallery_second": upload_count(gallery) > 1 ? gallery[1]["filename"] : null
        });
    }, {"csrf":false});

    app.get_named("profile.form", "/profile", func(ctx) {
        return ctx.response.html(Dom.render(Dom.h("div", {"class":"stack"}, [
            Forms.error_summary(ctx.request.old_errors()),
            Forms.text_field_from_ctx(ctx, "Name", "name", "", "Your name", "nameBox"),
            Forms.radio_group_from_ctx(ctx, "Role", "role", [
                {"value":"user","label":"User"},
                {"value":"admin","label":"Admin"}
            ], "user", "roleChoice"),
            Forms.select_field_from_ctx(ctx, "Team", "team", [
                {"value":"red","label":"Red"},
                {"value":"blue","label":"Blue"}
            ], "red", "teamBox", "Choose team"),
            Forms.checkbox_field_from_ctx(ctx, "Accept terms", "terms", "yes", false, "termsBox"),
            Forms.file_field("Avatar", "avatar", "avatarBox", ctx.request.old_error("avatar"), ".txt"),
            Dom.h("div", {"class":"session"}, ctx.request.old("name", ""))
        ])));
    });

    app.post_named("profile.submit", "/profile", func(ctx) {
        var form = Validation.from_request(ctx);
        form.text("name");
        form.text("role");
        form.text("team");
        form.bool("terms");
        form.require("name", "Name is required.");
        form.one_of("role", ["user", "admin"], "Pick a role.");
        form.one_of("team", ["red", "blue"], "Pick a team.");

        if (!form.value("terms", false)) {
            form.add_error("terms", "Please accept the terms.");
        }

        if (!form.is_valid()) {
            return ctx.response.redirect_to_with_input("profile.form", form.field_values_map(), form.field_errors_map());
        }

        return ctx.response.json({
            "ok": true,
            "values": form.field_values_map()
        });
    }, {"csrf":false});

    var timed = await app.handle(request("GET", "/assets/timed.txt"));
    expect("timed_status", timed["status"], 200);
    expect("timed_last_modified", timed["headers"]["Last-Modified"], "Wed, 01 Apr 2026 10:30:00 GMT");
    expect("timed_cache_control", timed["headers"]["Cache-Control"], "public, max-age=120");

    var timed_cached = await app.handle(request("GET", "/assets/timed.txt", "", {
        "Host":"localhost:8098",
        "If-Modified-Since":"Wed, 01 Apr 2026 10:30:00 GMT"
    }));
    expect("timed_cached_status", timed_cached["status"], 304);
    expect("timed_cached_body_empty", timed_cached["body"], "");

    var timed_stale = await app.handle(request("GET", "/assets/timed.txt", "", {
        "Host":"localhost:8098",
        "If-Modified-Since":"Wed, 01 Apr 2026 10:00:00 GMT"
    }));
    expect("timed_stale_status", timed_stale["status"], 200);
    expect("timed_stale_body", timed_stale["body"], "Timed body");

    var boundary = "----cfsBoundaryPhase7";
    var upload_inspect = await app.handle(request("POST", "/upload-inspect",
        "--" + boundary + "\r\n" +
        "Content-Disposition: form-data; name=\"title\"\r\n\r\n" +
        "Profile upload\r\n" +
        "--" + boundary + "\r\n" +
        "Content-Disposition: form-data; name=\"avatar\"; filename=\"avatar.txt\"\r\n" +
        "Content-Type: text/plain\r\n\r\n" +
        "avatar-body\r\n" +
        "--" + boundary + "\r\n" +
        "Content-Disposition: form-data; name=\"gallery\"; filename=\"g1.txt\"\r\n" +
        "Content-Type: text/plain\r\n\r\n" +
        "g1\r\n" +
        "--" + boundary + "\r\n" +
        "Content-Disposition: form-data; name=\"gallery\"; filename=\"g2.txt\"\r\n" +
        "Content-Type: text/plain\r\n\r\n" +
        "g2\r\n" +
        "--" + boundary + "--\r\n",
        {
            "Host":"localhost:8098",
            "Content-Type":"multipart/form-data; boundary=" + boundary
        }
    ));
    expect("upload_inspect_status", upload_inspect["status"], 200);
    var upload_meta = fromjson(upload_inspect["body"]);
    expect("upload_title", upload_meta["title"], "Profile upload");
    expect("upload_avatar_name", upload_meta["avatar_name"], "avatar.txt");
    expect("upload_avatar_original", upload_meta["avatar_original"], "avatar.txt");
    expect("upload_avatar_type", upload_meta["avatar_type"], "text/plain");
    expect("upload_avatar_body", upload_meta["avatar_body"], "avatar-body");
    expect("upload_avatar_size", upload_meta["avatar_size"], 11);
    expect("upload_gallery_count", upload_meta["gallery_count"], 2);
    expect("upload_gallery_second", upload_meta["gallery_second"], "g2.txt");

    var invalid_submit = await app.handle(request("POST", "/profile",
        "name=Ada&role=admin&team=blue",
        {
            "Host":"localhost:8098",
            "Content-Type":"application/x-www-form-urlencoded"
        }
    ));
    expect("invalid_submit_status", invalid_submit["status"], 303);
    expect("invalid_submit_location", invalid_submit["headers"]["Location"], "/profile");

    var cookie = set_cookie_value(invalid_submit["headers"]["Set-Cookie"]);
    var form_page = await app.handle(request("GET", "/profile", "", {
        "Host":"localhost:8098",
        "Cookie": cookie
    }));
    expect("form_page_status", form_page["status"], 200);
    expect_true("form_page_error_summary", str(form_page["body"]).contains("Please accept the terms."));
    expect_true("form_page_name_sticky", str(form_page["body"]).contains("value=\"Ada\""));
    expect_true("form_page_radio_sticky", str(form_page["body"]).contains("value=\"admin\" checked"));
    expect_true("form_page_select_sticky", str(form_page["body"]).contains("value=\"blue\" selected"));
    expect_true("form_page_file_field", str(form_page["body"]).contains("type=\"file\""));
    expect_true("form_page_old_echo", str(form_page["body"]).contains("<div class=\"session\">Ada</div>"));

    var form_page_again = await app.handle(request("GET", "/profile", "", {
        "Host":"localhost:8098",
        "Cookie": cookie
    }));
    expect("form_page_again_status", form_page_again["status"], 200);
    expect_true("form_page_old_consumed", !str(form_page_again["body"]).contains("value=\"Ada\""));
    expect_true("form_page_error_consumed", !str(form_page_again["body"]).contains("Please accept the terms."));
    expect_true("form_page_again_defaults_radio", str(form_page_again["body"]).contains("value=\"user\" checked"));
    expect_true("form_page_again_defaults_select", str(form_page_again["body"]).contains("value=\"red\" selected"));

    print("PHASE7_METADATA_UPLOADS_OLD_INPUT_OK");
}

var _ = await main();
