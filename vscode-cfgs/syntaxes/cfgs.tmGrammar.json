{
  "scopeName": "source.cfgs",
  "name": "CFGS",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.cfgs",
          "begin": "#\\+",
          "end": "\\+#"
        },
        {
          "name": "comment.line.number-sign.cfgs",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cfgs",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cfgs",
              "match": "\\\\(?:[ntr\\\\\"']|u[0-9A-Fa-f]{4}|x[0-9A-Fa-f]{2})"
            }
          ]
        },
        {
          "name": "string.quoted.single.cfgs",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.cfgs",
              "match": "\\\\(?:[ntr\\\\\"']|u[0-9A-Fa-f]{4}|x[0-9A-Fa-f]{2})"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.cfgs",
          "match": "\\b(?:0[xX][0-9A-Fa-f_]+|0[bB][01_]+|0[oO][0-7_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d[\\d_]*)?)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cfgs",
          "match": "\\b(?:if|else|while|do|for|foreach|in|break|continue|return|match|case|default|try|catch|finally|throw|await|yield|out)\\b"
        },
        {
          "name": "keyword.declaration.cfgs",
          "match": "\\b(?:var|const|func|class|enum|namespace|import|export|from|as|static|public|private|protected|async|new|delete)\\b"
        },
        {
          "name": "constant.language.cfgs",
          "match": "\\b(?:true|false|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.function.cfgs",
          "match": "\\b(?:func)\\s+([A-Za-z_][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.type.class.cfgs",
          "match": "\\b(?:class|enum|namespace)\\s+([A-Za-z_][A-Za-z0-9_\\.]*)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.cfgs",
          "match": "(\\+\\+|--|\\+=|-=|\\*=|/=|%=|==|!=|<=|>=|&&|\\|\\||\\?\\?|\\*\\*|<<|>>|[+\\-*/%<>=!&|^~?:.,;])"
        }
      ]
    }
  }
}
